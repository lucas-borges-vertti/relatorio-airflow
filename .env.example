# Arquivo base para o runtime do Airflow via docker compose --env-file
# Não salve credenciais reais neste arquivo versionado.

# Identificação do ambiente para logs e operação
APP_ENV=local

# Oracle usado pelo extrator Python do Airflow
ORACLE_HOST=oracle-host
ORACLE_PORT=1521
ORACLE_USER=oracle_user
ORACLE_PASSWORD=oracle_password
ORACLE_SERVICE_NAME=service_name
# Opcional: se informado, ORACLE_DSN tem prioridade sobre HOST/PORT/SERVICE_NAME
ORACLE_DSN=

# API backend usada pelo Airflow para upload, callback e links públicos
NESTJS_API_URL=http://host-gateway:4500
REPORTS_PUBLIC_URL=http://localhost:4500

# E-mail e notificações usados pela DAG
SMTP_USER=no-reply@example.com
SMTP_PASSWORD=
SMTP_FROM=no-reply@example.com
WHATSAPP_API_URL=https://api-whatsapp.example.com
WHATSAPP_API_KEY=
